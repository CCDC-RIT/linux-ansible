#!/bin/bash
set -euo pipefail

if [[ $EUID != 0 ]]; then
    echo "Please run this script as root!"
    exit 1
fi

FILES=(
  docker-compose.yml
  docker-compose.yaml
  compose.yml
  compose.yaml
  Makefile
  Dockerfile
  .dockerignore
  .env
  kubeconfig
  nginx.conf
  apache2.conf
  httpd.conf
  crontab
  id_rsa
  id_ed25519
  authorized_keys
  known_hosts
  config
  credentials
  config.php
  config.json
  config.yaml
  config.yml
  config.toml
  config.ini
  settings.py
  secrets.yml
  secrets.yaml
  vault.hcl
  *.htm
  *.html
  *.php
  *.pem
  *.key
  *.crt
  *.cer
)

HOME_EXTS=(
  *.txt
  *.pdf
  *.doc
  *.docx
  *.xlsx
  *.json
  *.xml
  *.toml
  *.sh
  *.py
  *.js
  *.md
  *.csv
  *.png
  *.jpg
  *.log
  *.zip
  *.7z
)

FILES_FIND=()
HOME_EXTS_FIND=()

for i in "${!FILES[@]}"; do
  if (( i == 0 )); then
    FILES_FIND+=(-iname "${FILES[$i]}")
  else
    FILES_FIND+=(-o -iname "${FILES[$i]}")
  fi
done

for i in "${!HOME_EXTS[@]}"; do
  if (( i == 0 )); then
    HOME_EXTS_FIND+=(-iname "${HOME_EXTS[$i]}")
  else
    HOME_EXTS_FIND+=(-o -iname "${HOME_EXTS[$i]}")
  fi
done

BACKUP_DIR="{{ backup_dir }}"

mkdir -p "$BACKUP_DIR/important_files"

touch "$BACKUP_DIR/important_files/log.txt"

backup_file() {
  local file="$1"
  echo "Backing up: $file" >> "$BACKUP_DIR/important_files/log.txt"
  cp --parents -a "$file" "$BACKUP_DIR/important_files" 2>/dev/null || true
}

if [ -d "/var/www" ]; then
  zip -r "$BACKUP_DIR/important_files/varwww.zip" /var/www
fi

if [ -d "/srv/www" ]; then
  zip -r "$BACKUP_DIR/important_files/srvwww.zip" /srv/www
fi

if [ -d "/opt" ]; then
  zip -r "$BACKUP_DIR/important_files/opt.zip" /opt
fi

find / -xdev \
  -path /proc -prune -o \
  -path /sys -prune -o \
  -path /dev -prune -o \
  -path /run -prune -o \
  -path /tmp -prune -o \
  -path /var/cache -prune -o \
  -path /usr/src -prune -o \
  -path /var/www -prune -o \
  -path /srv/www -prune -o \
  -path /opt -prune -o \
  -path "$BACKUP_DIR" -prune -o \
  -type f \( "${FILES_FIND[@]}" \) -print0 |
  while IFS= read -r -d '' file; do
      backup_file "$file"
  done

find /home -xdev \
  -type f \( "${HOME_EXTS_FIND[@]}" \) -print0 |
  while IFS= read -r -d '' file; do
      backup_file "$file"
  done