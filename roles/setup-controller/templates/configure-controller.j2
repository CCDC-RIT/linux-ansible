#!/bin/bash

set -euo pipefail

if [ -f /etc/os-release ]; then
    . /etc/os-release
else
    echo "Error: /etc/os-release not found. Cannot determine OS."
    exit 1
fi

if [[ ! -d /"{{ ansible_env.HOME }}/.ssh" ]]; then
    mkdir -p /"{{ ansible_env.HOME }}/.ssh"
    chown "{{ ansible_env.USER }}:{{ ansible_env.USER }}" /"{{ ansible_env.HOME }}/.ssh"
    chmod 700 /"{{ ansible_env.HOME }}/.ssh"
fi

if [[ ! -f "/{{ ansible_env.HOME }}/.ssh/id_ed25519" ]]; then
    ssh-keygen -t ed25519 -f "{{ ansible_env.HOME }}/.ssh/id_ed25519" -N \"\" -q
    chown "{{ ansible_env.USER }}:{{ ansible_env.USER }}" /"{{ ansible_env.HOME }}/.ssh/id_ed25519"
    chmod 640 /"{{ ansible_env.HOME }}/.ssh/id_ed25519"
fi



curl -L https://github.com/VirusTotal/yara/archive/refs/tags/v4.5.4.tar.gz -o "{{ ansible_env.HOME }}/linux-ansible/roles/setup-hosts-other/files/yara.tar.gz"
curl -L https://github.com/CCDC-RIT/YaraRules/raw/refs/heads/main/Linux.zip -o "{{ ansible_env.HOME }}/linux-ansible/roles/setup-hosts-other/files/Linux.zip"
curl -L https://github.com/CCDC-RIT/YaraRules/raw/refs/heads/main/Multi.zip -o "{{ ansible_env.HOME }}/linux-ansible/roles/setup-hosts-other/files/Multi.zip"
curl -L https://github.com/YARAHQ/yara-forge/releases/latest/download/yara-forge-rules-full.zip -o "{{ ansible_env.HOME }}/linux-ansible/roles/setup-hosts-other/files/yara-forge-rules-full.zip"

docker pull ghcr.io/ccdc-rit/password-manager:latest
docker save ghcr.io/ccdc-rit/password-manager:latest > "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-server/files/password-manager-latest.tar"
gzip "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-server/files/password-manager-latest.tar" --force

curl -L https://raw.githubusercontent.com/CCDC-RIT/Password-Manager/refs/heads/main/docker-compose.yml -o "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-server/files/docker-compose.yml"

if [ ! -d "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-client/files" ]; then
    mkdir -p "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-client/files"
fi

curl -L https://github.com/CCDC-RIT/Password-Manager/raw/refs/heads/main/client/linux -o "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-client/files/ccdc-password-manager-client"
curl -L https://raw.githubusercontent.com/CCDC-RIT/Password-Manager/refs/heads/main/client/linux.service  -o "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-client/files/ccdc-password-manager-client.service"

chmod 0774 "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-client/files/ccdc-password-manager-client"
chmod 0664 "{{ ansible_env.HOME }}/linux-ansible/roles/password-manager-client/files/ccdc-password-manager-client.service"